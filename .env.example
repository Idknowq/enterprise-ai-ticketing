COMPOSE_PROJECT_NAME=enterprise-ai-ticketing

APP_PORT=8080
SPRING_PROFILES_ACTIVE=dev

APP_DB_HOST=127.0.0.1
APP_DB_PORT=5432
APP_DB_NAME=ticketing
APP_DB_USERNAME=ticketing
APP_DB_PASSWORD=ticketing

APP_REDIS_HOST=127.0.0.1
APP_REDIS_PORT=6379

APP_RABBITMQ_HOST=127.0.0.1
APP_RABBITMQ_PORT=5672
APP_RABBITMQ_USERNAME=guest
APP_RABBITMQ_PASSWORD=guest
APP_RABBITMQ_MANAGEMENT_PORT=15672

APP_QDRANT_HOST=127.0.0.1
APP_QDRANT_HTTP_PORT=6333
APP_QDRANT_GRPC_PORT=6334
APP_QDRANT_API_KEY=

APP_TEMPORAL_HOST=127.0.0.1
APP_TEMPORAL_PORT=7233
APP_TEMPORAL_NAMESPACE=default
APP_TEMPORAL_UI_PORT=8088
TEMPORAL_POSTGRES_PORT=5433
TEMPORAL_POSTGRES_DB=temporal
TEMPORAL_POSTGRES_USER=temporal
TEMPORAL_POSTGRES_PASSWORD=temporal

APP_OTEL_COLLECTOR_GRPC_PORT=4317
APP_OTEL_COLLECTOR_HTTP_PORT=4318
APP_OTEL_EXPORTER_TRACES_ENDPOINT=http://127.0.0.1:4318/v1/traces
APP_OTEL_EXPORTER_METRICS_ENDPOINT=http://127.0.0.1:4318/v1/metrics

APP_JAEGER_UI_PORT=16686
APP_PROMETHEUS_PORT=9090
APP_GRAFANA_PORT=3001
APP_GRAFANA_USERNAME=admin
APP_GRAFANA_PASSWORD=admin

APP_AI_PROVIDER_TYPE=deepseek
APP_AI_PROVIDER_MODEL=deepseek-chat
APP_AI_PROVIDER_BASE_URL=你的 DeepSeek Base URL
APP_AI_PROVIDER_API_KEY=你的密钥
APP_AI_PROVIDER_CHAT_PATH=/v1/chat/completions
APP_AI_PROVIDER_TIMEOUT=20s

APP_KNOWLEDGE_EMBEDDING_ROUTING_MODE=local
APP_KNOWLEDGE_EMBEDDING_LOCAL_ENABLED=true
APP_KNOWLEDGE_EMBEDDING_LOCAL_PROVIDER_TYPE=ollama
APP_KNOWLEDGE_EMBEDDING_LOCAL_MODEL=nomic-embed-text:latest
APP_KNOWLEDGE_EMBEDDING_LOCAL_BASE_URL=http://127.0.0.1:11434
APP_KNOWLEDGE_EMBEDDING_LOCAL_EMBEDDING_PATH=/api/embeddings
APP_KNOWLEDGE_EMBEDDING_LOCAL_TIMEOUT=20s
APP_KNOWLEDGE_EMBEDDING_LOCAL_DIMENSION=768
APP_KNOWLEDGE_EMBEDDING_COMMERCIAL_ENABLED=false
APP_KNOWLEDGE_EMBEDDING_COMMERCIAL_PROVIDER_TYPE=openai
APP_KNOWLEDGE_EMBEDDING_COMMERCIAL_MODEL=text-embedding-3-large
APP_KNOWLEDGE_EMBEDDING_COMMERCIAL_BASE_URL=https://api.openai.com
APP_KNOWLEDGE_EMBEDDING_COMMERCIAL_API_KEY=
APP_KNOWLEDGE_EMBEDDING_COMMERCIAL_EMBEDDING_PATH=/v1/embeddings
APP_KNOWLEDGE_EMBEDDING_COMMERCIAL_TIMEOUT=20s
APP_KNOWLEDGE_EMBEDDING_COMMERCIAL_DIMENSION=3072
